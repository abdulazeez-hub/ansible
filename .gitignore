.vault_keys/
*.vault_pass
*.vault_pass.txt
*_pass.txt

# SSH private keys
*.pem
*.key
~/.ssh/

# Ansible retry files
*.retry

# Python cache
__pycache__/
*.pyc

# Editor artifacts that may cache decrypted content
*.swp
*.swo
*~
.DS_Store
